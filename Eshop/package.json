{
  "name": "eshop",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "npm --prefix worker run dev",
    "dev:all": "concurrently -n app,worker -c blue,green \"npm run dev\" \"npm run dev:worker\"",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vercel/edge-config": "^1.4.3",
    "ky": "^1.14.0",
    "v-viewer": "^3.0.23",
    "viewerjs": "^1.11.7",
    "vue": "^3.5.22",
    "vue-i18n": "^11.1.12",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.10",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.3",
    "vite": "^7.1.7",
    "vue-tsc": "^3.1.0"
  }
}